# Frontend environment for Vercel/local Next.js.
# Local Django:
DJANGO_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
TAVILY_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Microsoft Clarity project id (public, from https://clarity.microsoft.com/projects). A default is baked into the app and only loads in production builds; set this only to point at a different Clarity project.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Production example after Render backend is live:
# DJANGO_BASE_URL=https://webchuandoanla-backend.onrender.com
# NEXT_PUBLIC_API_BASE_URL=https://webchuandoanla-backend.onrender.com
# DEEPSEEK_API_KEY=<set in Vercel, do not commit>
# DEEPSEEK_MODEL=deepseek-v4-flash
# TAVILY_API_KEY=<set in Vercel, do not commit>
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=<Google OAuth Web Client ID>

# Backend environment for Render:
# DJANGO_SUPERUSER_USERNAME=<set only in Render>
# DJANGO_SUPERUSER_EMAIL=<set only in Render>
# DJANGO_SUPERUSER_PASSWORD=<set only in Render>
# GOOGLE_CLIENT_ID=<same Google OAuth Web Client ID>
# SEPAY_WEBHOOK_SECRET=<random 32-byte secret; configure the same value in SePay>
# SEPAY_API_KEY=<temporary fallback only while migrating from API Key authentication>
# SEPAY_BANK_CODE=BIDV
# SEPAY_BANK_NAME=BIDV
# SEPAY_ACCOUNT_NUMBER=<recipient bank account number>
# SEPAY_ACCOUNT_NAME=<recipient account holder name>
# SEPAY_PAYMENT_PREFIX=AGM
# SEPAY_WEBHOOK_MAX_AGE_SECONDS=300
# SEPAY_ORDER_TTL_MINUTES=30
# SEPAY_SUBSCRIPTION_DAYS=30
