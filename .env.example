# Frontend environment for Vercel/local Next.js.
# Local Django:
DJANGO_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
TAVILY_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Production example after Render backend is live:
# DJANGO_BASE_URL=https://webchuandoanla-backend.onrender.com
# NEXT_PUBLIC_API_BASE_URL=https://webchuandoanla-backend.onrender.com
# DEEPSEEK_API_KEY=<set in Vercel, do not commit>
# DEEPSEEK_MODEL=deepseek-v4-flash
# TAVILY_API_KEY=<set in Vercel, do not commit>
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=<Google OAuth Web Client ID>

# Backend environment for Render:
# GOOGLE_CLIENT_ID=<same Google OAuth Web Client ID>
