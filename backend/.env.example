SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional secure administrator provisioning. Leave all three empty to skip.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Copy the complete Supabase Postgres connection string into the local .env file.
SUPABASE_DB_URL=

# CNN model checkpoint. Default backend path is ../best_model.pth.
CNN_MODEL_PATH=

# Prefer remote Hugging Face Space FastAPI when set.
# Example: https://username-agromind-cnn-api.hf.space
CNN_API_URL=
CNN_API_TOKEN=

# Next.js frontend URL for CORS
FRONTEND_ORIGIN=http://127.0.0.1:3000

# Optional (comma-separated) for multi-env deploys
# CORS_ALLOWED_ORIGINS=https://leafiq.example.com,https://staging-leafiq.example.com
CORS_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
CORS_ALLOWED_ORIGIN_REGEXES=
# CSRF_TRUSTED_ORIGINS=https://api-leafiq.example.com
CSRF_TRUSTED_ORIGINS=

# SePay payment gateway
SEPAY_WEBHOOK_SECRET=
SEPAY_API_KEY=
SEPAY_BANK_CODE=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
SEPAY_PAYMENT_PREFIX=AGM
SEPAY_WEBHOOK_MAX_AGE_SECONDS=300
SEPAY_ORDER_TTL_MINUTES=30
SEPAY_SUBSCRIPTION_DAYS=30

# Free production deploy example:
# DEBUG=False
# ALLOWED_HOSTS=.onrender.com
# FRONTEND_ORIGIN=https://your-vercel-project.vercel.app
# CORS_ALLOWED_ORIGINS=https://your-vercel-project.vercel.app
# CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
# CSRF_TRUSTED_ORIGINS=https://webchuandoanla-backend.onrender.com,https://*.vercel.app
